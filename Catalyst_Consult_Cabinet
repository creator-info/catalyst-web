const { useState, useEffect } = React;

        const LESSONS = [
            { id: 1, title: "УРОК 1: ВВЕДЕНИЕ В ИНКУБАЦИЮ", desc: "Подробное описание методологии, практические задания и чек-листы для подготовки вашего проекта к инвестициям." },
            { id: 2, title: "УРОК 2: АНАЛИЗ РЫНКА", desc: "Оценка объема рынка (TAM, SAM, SOM), конкурентный анализ и выявление свободных ниш." },
            { id: 3, title: "УРОК 3: UNIT-ЭКОНОМИКА", desc: "Расчет стоимости привлечения клиента (CAC), пожизненной ценности (LTV) и маржинальности." },
            { id: 4, title: "УРОК 4: MVP И CUSTDEV", desc: "Создание минимально жизнеспособного продукта и проведение глубинных интервью с пользователями." },
            { id: 5, title: "УРОК 5: ФИНАНСОВАЯ МОДЕЛЬ", desc: "Построение 3-х летней финансовой модели проекта (P&L, Cash Flow) для инвесторов." },
            { id: 6, title: "УРОК 6: ЮРИДИЧЕСКАЯ СТРУКТУРА", desc: "Регистрация интеллектуальной собственности, выбор формы (ТОО/МФЦА) и корпоративный договор." },
            { id: 7, title: "УРОК 7: МАРКЕТИНГ И ПРОДАЖИ", desc: "Построение воронки продаж, GTM-стратегия (Go-to-Market) и B2B/B2C каналы." },
            { id: 8, title: "УРОК 8: ПОДГОТОВКА PITCH DECK", desc: "Структура идеальной презентации для инвестора. Оформление слайдов и питчинг." },
            { id: 9, title: "УРОК 9: РАБОТА С ИНВЕСТОРАМИ", desc: "Где искать инвесторов, оценка проекта (Valuation) и структурирование сделки (Term Sheet)." },
            { id: 10, title: "УРОК 10: МАСШТАБИРОВАНИЕ", desc: "Стратегия выхода на международные рынки, экспорт и масштабирование команды." }
        ];

        const App = () => {
            // СОСТОЯНИЯ АВТОРИЗАЦИИ
            const [isAuth, setIsAuth] = useState(false);
            const [loginData, setLoginData] = useState({ bin: '', email: '' });
            const [authLoading, setAuthLoading] = useState(false);
            const [authError, setAuthError] = useState('');
            const [userCompany, setUserCompany] = useState('');

            // СОСТОЯНИЯ КОНТЕНТА
            const [activeTab, setActiveTab] = useState('courses');
            const [selectedLesson, setSelectedLesson] = useState(0);
            const [unlockedCount, setUnlockedCount] = useState(1);
            const [showTest, setShowTest] = useState(false);
            const [testPassed, setTestPassed] = useState(false);

            // ТВОЯ НОВАЯ ССЫЛКА GOOGLE SCRIPT
            const SCRIPT_URL = "https://script.google.com/macros/s/AKfycbxqjVpRJUIlLLs95dwKAdNGyKRad8gDt1AnwwAktveXzjtYnbUVOn8RquB43o7lE_44/exec";

            // Функция входа
            const checkAuth = async (e) => {
                e.preventDefault();
                setAuthError('');
                
                if (loginData.bin.length !== 12) {
                    setAuthError('БИН должен содержать 12 цифр');
                    return;
                }

                setAuthLoading(true);
                try {
                    const response = await fetch(`${SCRIPT_URL}?action=login&bin=${loginData.bin}&email=${loginData.email.toLowerCase().trim()}`);
                    const result = await response.json();

                    if (result.auth) {
                        setIsAuth(true);
                        setUserCompany(result.company);
                        // Запоминаем дату входа для открытия уроков, если еще нет
                        if(!localStorage.getItem('catalyst_reg_date')) {
                            localStorage.setItem('catalyst_reg_date', new Date().toISOString());
                        }
                    } else {
                        setAuthError('Данные не найдены. Проверьте БИН и Email или свяжитесь с поддержкой.');
                    }
                } catch (err) {
                    setAuthError('Ошибка связи с сервером. Попробуйте позже.');
                } finally {
                    setAuthLoading(false);
                }
            };

            // Логика разблокировки уроков
            useEffect(() => {
                if (isAuth) {
                    const regDateStr = localStorage.getItem('catalyst_reg_date');
                    const regDate = new Date(regDateStr);
                    regDate.setHours(0,0,0,0);
                    const today = new Date();
                    today.setHours(0,0,0,0);
                    
                    const diffTime = today - regDate;
                    const diffDays = Math.floor(diffTime / (1000 * 60 * 60 * 24));
                    setUnlockedCount(Math.min(10, diffDays + 1));

                    if(localStorage.getItem('catalyst_test_passed') === 'true') {
                        setTestPassed(true);
                    }
                }
            }, [isAuth]);

            // ЭКРАН ВХОДА
            if (!isAuth) {
                return (
                    <div className="min-h-screen flex items-center justify-center bg-[#0f172a] p-6">
                        <div className="max-w-md w-full bg-white rounded-[3rem] p-10 shadow-2xl text-center">
                            <div className="w-16 h-16 bg-[#facc15] rounded-2xl flex items-center justify-center font-black text-2xl text-[#0f172a] mx-auto mb-6">C</div>
                            <h2 className="text-2xl font-black uppercase text-[#0f172a] mb-8 tracking-tighter">Вход в Академию</h2>
                            
                            <form onSubmit={checkAuth} className="space-y-4 text-left">
                                <div>
                                    <label className="text-[10px] font-black uppercase text-slate-400 ml-2 mb-1 block">Ваш БИН / ИИН</label>
                                    <input 
                                        type="text" 
                                        required
                                        placeholder="123456789012"
                                        className="w-full bg-slate-50 border border-slate-200 p-4 rounded-xl text-slate-900 outline-none focus:border-[#facc15]"
                                        value={loginData.bin}
                                        onChange={(e) => setLoginData({...loginData, bin: e.target.value})}
                                    />
                                </div>
                                <div>
                                    <label className="text-[10px] font-black uppercase text-slate-400 ml-2 mb-1 block">Email (при регистрации)</label>
                                    <input 
                                        type="email" 
                                        required
                                        placeholder="example@mail.com"
                                        className="w-full bg-slate-50 border border-slate-200 p-4 rounded-xl text-slate-900 outline-none focus:border-[#facc15]"
                                        value={loginData.email}
                                        onChange={(e) => setLoginData({...loginData, email: e.target.value})}
                                    />
                                </div>
                                
                                {authError && <p className="text-red-500 text-[11px] font-bold text-center px-2">{authError}</p>}
                                
                                <button 
                                    type="submit" 
                                    disabled={authLoading}
                                    className="w-full bg-[#0f172a] text-white font-black py-4 rounded-xl hover:scale-105 transition-transform uppercase text-xs tracking-widest disabled:opacity-50"
                                >
                                    {authLoading ? 'ПРОВЕРКА...' : 'ВОЙТИ В КАБИНЕТ'}
                                </button>
                            </form>
                            <a href="index.html" className="inline-block mt-8 text-slate-400 text-[10px] font-black uppercase hover:text-[#facc15]">Вернуться на сайт</a>
                        </div>
                    </div>
                );
            }

            // ЭКРАН КАБИНЕТА (ТВОЙ ТЕКУЩИЙ КОД)
            return (
                <div className="flex h-screen overflow-hidden bg-[#f8fafc]">
                    {/* ... Тут идет весь твой код, который начинается с ЛЕВАЯ ПАНЕЛЬ ... */}
                    {/* В месте, где выводится приветствие, можешь добавить: {userCompany} */}
                </div>
            );
        };
